# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=example
VITE_SUPABASE_ANON_KEY=key

# Optional. If OAuth/email redirects go to production when testing from another device,
# set this to a base URL you add under Supabase → Auth → URL Configuration → Redirect URLs.
# Example: http://192-168-1-5.nip.io:5173/surf-report/
# VITE_AUTH_REDIRECT_TO=
